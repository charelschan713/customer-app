{
  "expo": {
    "name": "ASChauffeured",
    "slug": "customer-app",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aschauffeured",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aschauffeured.customer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f14"
      },
      "package": "com.aschauffeured.customer"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#c8a96b",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "ASChauffeured"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    },
    "owner": "charelschan713"
  }
}
