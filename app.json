{
  "expo": {
    "name": "ASChauffeured",
    "slug": "customer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aschauffeured",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aschauffeured.customer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#0d0f14" },
      "package": "com.aschauffeured.customer"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#c8a96b",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "ASChauffeured"
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    },
    "owner": "charelschan713"
  }
}
